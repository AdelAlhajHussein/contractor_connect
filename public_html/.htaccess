Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # --- Force HTTPS + remove www (optional but recommended) ---
    RewriteCond %{HTTPS} !=on [OR]
    RewriteCond %{HTTP_HOST} ^www\. [NC]
    RewriteRule ^ https://contractorconnect.cc%{REQUEST_URI} [R=301,L]

    # --- Serve existing files/folders directly (CSS/JS/Images) ---
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # --- Otherwise, route through CodeIgniter front controller ---
    RewriteRule ^ index.php [L]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 index.php
</IfModule>
